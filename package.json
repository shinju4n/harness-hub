{
  "name": "harness-hub",
  "version": "0.1.0",
  "description": "A local desktop dashboard for viewing and managing your Claude Code harness",
  "author": "shinju4n",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shinju4n/harness-hub.git"
  },
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "electron:dev": "tsc -p tsconfig.electron.json && electron .",
    "electron:build": "next build && tsc -p tsconfig.electron.json && electron-builder",
    "electron:build:mac": "next build && tsc -p tsconfig.electron.json && electron-builder --mac",
    "electron:build:win": "next build && tsc -p tsconfig.electron.json && electron-builder --win"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "gray-matter": "^4.0.3",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
