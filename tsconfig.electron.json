{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "outDir": "electron",
    "rootDir": "electron-src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["electron-src/**/*"],
  "exclude": ["electron-src/__tests__/**/*"]
}
